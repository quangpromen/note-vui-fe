# --- PRO/SECURITY .GITIGNORE FOR REACT (VITE) ---

# Dependency directories
node_modules/
jspm_packages/

# Build outputs
dist/
dist-ssr/
build/
.vercel
.netlify
.vite/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- SECURITY: Secrets & Environment Variables ---
# NEVER commit secrets to version control
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Ignore potential backups or history of env files
.env.bak
.env.old
*.env

# Testing
coverage/
__snapshots__/

# Editor / IDE configuration
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history/

# Operating System Files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# TypeScript
*.tsbuildinfo

# AI Agent Specifics (Keeping rules, excluding temporary artifacts)
.agent/tmp/
.agent/logs/
.agent/cache/
# Note: Keep .agent/skills and .agent/workflows committed for team collaboration

# Production-only
node_modules.bak/
